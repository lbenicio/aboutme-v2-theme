{{- $base := .Site.Params.basePath | default "" -}}
[
{{- $pages := .Pages.ByDate.Reverse -}}
{{- range $i, $p := $pages -}}
  {{- if $i }},{{ end -}}
  {
    "slug": {{ $p.File.TranslationBaseName | jsonify }},
    "title": {{ $p.Title | jsonify }},
    {{- with $p.Params.cover }}"cover": {{ . | relURL | jsonify }},{{ end -}}
    {{- with $p.Params.description }}"description": {{ . | jsonify }},{{ end -}}
    {{- with $p.Params.author }}"author": {{ . | jsonify }},{{ end -}}
    {{- with $p.Date }}"date": {{ . | time.Format "2006-01-02" | jsonify }},{{ end -}}
    {{- $year := "" -}}
    {{- if isset $p.Params "year" -}}
      {{- $year = printf "%v" $p.Params.year -}}
    {{- else if ne (printf "%T" $p.Date) "<nil>" -}}
      {{- $year = ($p.Date | time.Format "2006") -}}
    {{- end -}}
    {{- with $year }}"year": {{ . | jsonify }},{{ end -}}
    {{- with $p.Params.categories }}"categories": {{ . | jsonify }},{{ end -}}
    {{- with $p.Params.tags }}"tags": {{ . | jsonify }},{{ end -}}
    "link": {{ (printf "%s%s" $base $p.RelPermalink) | jsonify }}
  }
{{- end -}}
]
