########################################
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

########################################
# Node.js / JavaScript
########################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# General logs
logs/
*.log
*.log.*

########################################
# Environment files (keep examples tracked)
########################################
.env
.env.*
!.env.example
cmds.txt

########################################
# Hugo
########################################
# Default Hugo outputs (sometimes generated if running hugo locally without custom paths)
public/
resources/
.hugo_build.lock
# Common Hugo cache dir (if ever enabled)
.hugo_cache/

########################################
# Build artifacts / caches
########################################
.build/
dist/
build/
tmp/
temp/
export/
.cache/
.postcss-cache

########################################
# Coverage / test outputs
########################################
coverage/
.nyc_output/
test-results/

########################################
# Editors / IDEs
########################################
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

########################################
